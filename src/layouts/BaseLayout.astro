---
import { getCollection } from "astro:content";
import "../styles/global.css";
import { siteConfig } from "../site.config";
import { withBase } from "../lib/url";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
};

const {
  title = siteConfig.siteName,
  description = "Tech Mage: articles and thoughts",
  canonical,
} = Astro.props as Props;

const homeHref = withBase("/");
const notesHref = withBase("/notes/");
const searchHref = withBase("/search/");
const styleGuideHref = withBase("/style-guide/");
const canonicalHref = canonical || new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const categories = (await getCollection("categories")).sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" href={withBase("/brand/tech-mage-icon.svg")} type="image/svg+xml" />
    <link rel="shortcut icon" href={withBase("/brand/tech-mage-icon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-wrap">
      <header class="topbar">
        <div class="topbar-inner ui-raised-panel">
          <a class="logo" href={homeHref} aria-label="Tech Mage home">
            <img class="logo-mark" src={withBase("/brand/tech-mage-icon.svg")} alt="" width="24" height="24" />
            <span>Tech Mage</span>
          </a>
          <nav class="primary-links" aria-label="Primary navigation">
            {categories.map((category) => (
              <a class="ui-nav-item" href={withBase(`/category/${category.data.slug}/`)}>{category.data.name}</a>
            ))}
            <a class="ui-nav-item" href={notesHref}>Thoughts</a>
            <a class="ui-nav-item" href={styleGuideHref}>Style Guide</a>
          </nav>
          <form class="search ui-inset-panel" id="nav-search-form" action={searchHref} method="get" autocomplete="off">
            <input id="nav-search-input" type="search" name="q" placeholder="Search title, category, tags" />
            <button class="search-toggle ui-icon-button" id="nav-search-toggle" type="button" aria-label="Open search">
              <img src={withBase("/icons/search-flaticon-style.svg")} alt="" />
            </button>
            <div id="nav-search-suggest" class="suggest hidden" role="listbox" aria-label="Search suggestions"></div>
          </form>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner ui-content-container">
          <p class="muted">Tech Mage · Engineering, AI, leadership, and durable writing.</p>
          <p class="muted">Designed as a calm control surface for deep technical thinking.</p>
        </div>
      </footer>
    </div>

    <script is:inline define:vars={{ base: siteConfig.basePath }}>
      const keywordsPath = (base === "/" ? "" : base) + "/search-keywords.json";

      const form = document.getElementById("nav-search-form");
      const toggle = document.getElementById("nav-search-toggle");
      const input = document.getElementById("nav-search-input");
      const suggest = document.getElementById("nav-search-suggest");
      let records = [];
      let loaded = false;
      let suggestions = [];
      let activeIndex = -1;

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      async function ensureRecords() {
        if (loaded) return;
        try {
          const res = await fetch(keywordsPath);
          const json = await res.json();
          records = Array.isArray(json) ? json.map((x) => String(x).toLowerCase()) : [];
          loaded = true;
        } catch {
          loaded = true;
          records = [];
        }
      }

      function renderSuggest(items) {
        suggestions = items;
        activeIndex = -1;
        if (!items.length) {
          suggest.innerHTML = "";
          suggest.classList.add("hidden");
          return;
        }
        suggest.innerHTML = items
          .map((value, idx) => {
            const safeValue = escapeHtml(value);
            return `<button type=\"button\" class=\"item\" role=\"option\" data-index=\"${idx}\" data-value=\"${safeValue}\"><span class=\"term\">${safeValue}</span></button>`;
          })
          .join("");
        suggest.classList.remove("hidden");
      }

      function setActiveIndex(next) {
        if (!suggestions.length) {
          activeIndex = -1;
          return;
        }
        const max = suggestions.length - 1;
        if (next < 0) activeIndex = max;
        else if (next > max) activeIndex = 0;
        else activeIndex = next;

        const items = Array.from(suggest.querySelectorAll(".item"));
        items.forEach((item, idx) => {
          const selected = idx === activeIndex;
          item.classList.toggle("active", selected);
          item.setAttribute("aria-selected", selected ? "true" : "false");
        });
      }

      function selectActive(submit) {
        if (activeIndex < 0 || activeIndex >= suggestions.length) return false;
        input.value = suggestions[activeIndex];
        renderSuggest([]);
        if (submit) form?.requestSubmit();
        return true;
      }

      async function onInput() {
        const q = input.value.trim().toLowerCase();
        if (!q) {
          renderSuggest([]);
          return;
        }
        await ensureRecords();
        const items = records
          .map((value) => ({
            value,
            score: (value.startsWith(q) ? 4 : 0) + (value.includes(q) ? 2 : 0) - value.length / 200,
          }))
          .filter((x) => x.value.includes(q))
          .filter((x, idx, arr) => arr.findIndex((y) => y.value === x.value) === idx)
          .sort((a, b) => b.score - a.score || a.value.localeCompare(b.value))
          .slice(0, 10)
          .map((x) => x.value);
        renderSuggest(items);
      }

      function onInputKeydown(e) {
        if (!suggestions.length) return;
        if (e.key === "ArrowDown") {
          e.preventDefault();
          setActiveIndex(activeIndex + 1);
          return;
        }
        if (e.key === "ArrowUp") {
          e.preventDefault();
          setActiveIndex(activeIndex - 1);
          return;
        }
        if (e.key === "Tab" && activeIndex >= 0) {
          e.preventDefault();
          selectActive(false);
          return;
        }
        if (e.key === "Enter" && activeIndex >= 0) {
          e.preventDefault();
          selectActive(true);
          return;
        }
        if (e.key === "Escape") {
          renderSuggest([]);
          if (!input?.value?.trim()) form?.classList.remove("expanded");
        }
      }

      function onSuggestClick(e) {
        const el = e.target?.closest?.(".item");
        if (!el) return;
        const value = el.getAttribute("data-value");
        if (!value) return;
        input.value = value;
        renderSuggest([]);
        form?.requestSubmit();
      }

      function onSuggestMove(e) {
        const el = e.target?.closest?.(".item");
        if (!el) return;
        const idx = Number(el.getAttribute("data-index"));
        if (Number.isFinite(idx)) setActiveIndex(idx);
      }

      input?.addEventListener("focus", ensureRecords);
      input?.addEventListener("focus", () => form?.classList.add("expanded"));
      input?.addEventListener("input", onInput);
      input?.addEventListener("keydown", onInputKeydown);
      suggest?.addEventListener("click", onSuggestClick);
      suggest?.addEventListener("mousemove", onSuggestMove);
      form?.addEventListener("submit", () => suggest.classList.add("hidden"));
      toggle?.addEventListener("click", () => {
        form?.classList.add("expanded");
        input?.focus();
      });
      document.addEventListener("click", (e) => {
        if (!form?.contains(e.target)) {
          suggest.classList.add("hidden");
          if (!input?.value?.trim()) form?.classList.remove("expanded");
        }
      });
    </script>
  </body>
</html>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0.8rem 1rem;
    backdrop-filter: blur(10px);
    background: linear-gradient(180deg, rgba(7, 10, 15, 0.93), rgba(7, 10, 15, 0.7));
  }

  .topbar-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0.7rem 0.9rem;
    display: grid;
    gap: 0.8rem;
    align-items: center;
    grid-template-columns: auto 1fr auto;
    border-radius: 1.1rem;
  }

  .logo {
    font-size: 1.3rem;
    color: #f8d5a7;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    white-space: nowrap;
  }

  .logo-mark {
    width: 1.2rem;
    height: 1.2rem;
    display: block;
    filter: drop-shadow(0 0 10px rgba(243, 165, 58, 0.25));
  }

  .primary-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .search {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 2.45rem;
    min-width: 2.45rem;
    height: 2.45rem;
    overflow: visible;
    transition: width var(--transition-base), border-color var(--transition-fast);
  }

  .search-toggle {
    all: unset;
    position: absolute;
    inset: 0;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .search-toggle img {
    width: 1rem;
    height: 1rem;
    filter: brightness(0) invert(1);
    opacity: 0.95;
  }

  .search input {
    width: 0;
    opacity: 0;
    pointer-events: none;
    border: none;
    box-shadow: none;
    padding: 0.52rem 2.6rem 0.52rem 0.95rem;
    margin: 0;
    background: transparent;
    transition: width var(--transition-base), opacity var(--transition-fast);
  }

  .search.expanded,
  .search:focus-within {
    width: min(360px, 46vw);
    border-color: rgba(243, 165, 58, 0.35);
  }

  .search.expanded input,
  .search:focus-within input {
    width: 100%;
    opacity: 1;
    pointer-events: auto;
  }

  .suggest {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    padding: 0.36rem;
    border: 1px solid var(--stroke-subtle);
    border-radius: 0.95rem;
    background: linear-gradient(170deg, rgba(18, 25, 36, 0.98), rgba(11, 16, 24, 1));
    box-shadow: var(--shadow-raised-lg);
    max-height: 290px;
    overflow-y: auto;
  }

  .suggest :global(.item) {
    appearance: none;
    width: 100%;
    border: 0;
    text-align: left;
    padding: 0.58rem 0.65rem;
    border-radius: 0.7rem;
    color: var(--text-secondary);
    background: transparent;
    cursor: pointer;
    font: inherit;
  }

  .suggest :global(.item .term) {
    text-transform: lowercase;
    letter-spacing: 0.01em;
  }

  .suggest :global(.item:hover),
  .suggest :global(.item.active) {
    color: var(--text-primary);
    background: rgba(243, 165, 58, 0.17);
  }

  .hidden {
    display: none;
  }

  .site-footer {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.35rem 1.5rem;
  }

  .footer-inner {
    padding: 1rem 1.15rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 980px) {
    .topbar {
      padding: 0.7rem 0.8rem;
    }

    .topbar-inner {
      grid-template-columns: 1fr;
    }

    .search {
      width: 100%;
      min-width: 100%;
      justify-self: stretch;
    }

    .search.expanded,
    .search:focus-within {
      width: 100%;
    }

    .site-footer {
      padding: 0 1rem 1.2rem;
    }
  }
</style>
