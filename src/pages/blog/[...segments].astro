---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatContentDate } from "../../lib/date";
import { resolveAuthorSlug, resolvePermalink, resolveNamespace } from "../../lib/content-path";
import { resolveCanonicalUrl, resolveSocialDescription } from "../../lib/seo";
import { withBase } from "../../lib/url";
import { buildResponsiveImage } from "../../lib/media";
import { slugifyTag } from "../../lib/tags";
import { isVisible } from "../../lib/visibility";
import { estimateReadingStats } from "../../lib/reading";

type Props = {
  post: CollectionEntry<"posts">;
};

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts
    .filter((p) => isVisible(p.data.publishedAt))
    .map((post) => {
      const permalink = resolvePermalink({ ...post, collection: "posts" });
      const segments = permalink.replace(/^\/blog\//, "").replace(/\/$/, "");
      return {
        params: { segments },
        props: { post },
      };
    });
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
const permalink = resolvePermalink({ ...post, collection: "posts" });
const canonical = resolveCanonicalUrl(permalink, post.data.canonical);
const categorySlug = resolveNamespace({ ...post, collection: "posts" });
const description = resolveSocialDescription(post.data.description, post.body);
const authorSlug = resolveAuthorSlug({ ...post, collection: "posts" });
const [authors, categories, posts] = await Promise.all([
  getCollection("authors"),
  getCollection("categories"),
  getCollection("posts"),
]);

const visiblePosts = posts.filter((entry) => isVisible(entry.data.publishedAt));
const author = authors.find((entry) => entry.data.slug === authorSlug);
const category = categories.find((entry) => entry.data.slug === categorySlug);
const heroImage = buildResponsiveImage(post.data.image, post.slug, 1600, 900, "(min-width: 1120px) 1120px, 100vw");
const reading = estimateReadingStats(post.body || "");

const tocItems = Array.from(post.body.matchAll(/^##\s+(.+)$/gm)).map((match) => {
  const text = match[1].trim();
  const id = text
    .toLowerCase()
    .replace(/[^\w\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-");
  return { text, id };
});

const scopedPosts = visiblePosts
  .filter((entry) => resolveNamespace({ ...entry, collection: "posts" }) === categorySlug)
  .sort((a, b) => {
    const aa = new Date(a.data.publishedAt || 0).getTime();
    const bb = new Date(b.data.publishedAt || 0).getTime();
    return aa - bb;
  });
const currentIndex = scopedPosts.findIndex((entry) => entry.id === post.id);
const prevPost = currentIndex > 0 ? scopedPosts[currentIndex - 1] : undefined;
const nextPost = currentIndex >= 0 && currentIndex < scopedPosts.length - 1 ? scopedPosts[currentIndex + 1] : undefined;

const relatedPosts = visiblePosts
  .filter((entry) => entry.id !== post.id)
  .map((entry) => {
    const sameCategory = resolveNamespace({ ...entry, collection: "posts" }) === categorySlug;
    const sharedTags = (entry.data.tags || []).filter((tag) => (post.data.tags || []).includes(tag)).length;
    const score = sharedTags * 3 + (sameCategory ? 2 : 0);
    return { entry, score };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map((item) => item.entry);

const seriesSlug = post.data.series;
const seriesPosts = seriesSlug
  ? visiblePosts
      .filter((entry) => entry.data.series === seriesSlug)
      .sort((a, b) => {
        const apart = a.data.part || 9999;
        const bpart = b.data.part || 9999;
        if (apart !== bpart) return apart - bpart;
        const aa = new Date(a.data.publishedAt || 0).getTime();
        const bb = new Date(b.data.publishedAt || 0).getTime();
        return aa - bb;
      })
  : [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description,
  image: heroImage.src,
  url: canonical,
  datePublished: post.data.publishedAt ? new Date(post.data.publishedAt as never).toISOString() : undefined,
  dateModified: post.data.updatedAt ? new Date(post.data.updatedAt as never).toISOString() : undefined,
  author: {
    "@type": "Person",
    name: author?.data.name || authorSlug,
    url: withBase(`/author/${authorSlug}/`),
  },
};
---

<BaseLayout title={`${post.data.title} | Tech Mage`} description={description} canonical={canonical}>
  <article class="post-layout stack">
    <figure class="hero-image-wrap ui-raised-panel-strong fade-in">
      <img
        class="hero-image"
        src={heroImage.src}
        srcset={heroImage.srcset}
        sizes={heroImage.sizes}
        width={heroImage.width}
        height={heroImage.height}
        alt={post.data.title}
        loading="eager"
        decoding="async"
      />
      <div class="hero-shade"></div>
      <div class="hero-copy stack">
        <span class="badge">{category?.data.name || categorySlug}</span>
        <h1>{post.data.title}</h1>
      </div>
    </figure>

    <section class="content-grid">
      <div class="article ui-content-container stack">
        <header class="stack meta-top">
          <div class="pill-row">
            <span class="pill">{formatContentDate(post.data.publishedAt)}</span>
            <span class="pill">{reading.minutes} min read</span>
            <span class="pill">{reading.words.toLocaleString()} words</span>
            {post.data.updatedAt && <span class="pill">Updated {formatContentDate(post.data.updatedAt)}</span>}
            {seriesSlug && <a class="pill" href={withBase(`/series/${seriesSlug}/`)}>Series: {seriesSlug}</a>}
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>

        {(post.data.tags || []).length > 0 && (
          <footer class="tags-row">
            {(post.data.tags || []).map((tag) => <a class="tag" href={withBase(`/tag/${slugifyTag(tag)}/`)}>#{tag}</a>)}
          </footer>
        )}

        {(prevPost || nextPost) && (
          <nav class="post-nav">
            {prevPost ? <a class="ui-raised-panel nav-link" href={withBase(resolvePermalink({ ...prevPost, collection: "posts" }))}>← {prevPost.data.title}</a> : <span></span>}
            {nextPost ? <a class="ui-raised-panel nav-link" href={withBase(resolvePermalink({ ...nextPost, collection: "posts" }))}>{nextPost.data.title} →</a> : <span></span>}
          </nav>
        )}

        {relatedPosts.length > 0 && (
          <section class="related stack">
            <h3>Related Articles</h3>
            <ul>
              {relatedPosts.map((entry) => (
                <li><a href={withBase(resolvePermalink({ ...entry, collection: "posts" }))}>{entry.data.title}</a></li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <aside class="side">
        <section class="ui-content-container side-card stack">
          <h3>Details</h3>
          <dl>
            <div>
              <dt>Category</dt>
              <dd><a href={withBase(`/category/${categorySlug}/`)}>{category?.data.name || categorySlug}</a></dd>
            </div>
            <div>
              <dt>Author</dt>
              <dd><a href={withBase(`/author/${authorSlug}/`)}>{author?.data.name || authorSlug}</a></dd>
            </div>
            <div>
              <dt>Published</dt>
              <dd>{formatContentDate(post.data.publishedAt)}</dd>
            </div>
            <div>
              <dt>Reading Time</dt>
              <dd>{reading.minutes} min</dd>
            </div>
          </dl>
        </section>

        {tocItems.length > 0 && (
          <section class="ui-content-container side-card stack">
            <h3>Table of Contents</h3>
            <ul>
              {tocItems.map((item) => (
                <li><a class="toc-link" href={`#${item.id}`} data-target={item.id}>{item.text}</a></li>
              ))}
            </ul>
          </section>
        )}

        {seriesPosts.length > 1 && (
          <section class="ui-content-container side-card stack">
            <h3>Series</h3>
            <ul>
              {seriesPosts.map((entry) => (
                <li>
                  <a href={withBase(resolvePermalink({ ...entry, collection: "posts" }))}>
                    {entry.data.part ? `Part ${entry.data.part}: ` : ""}{entry.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </section>
  </article>

  <script is:inline>
    const headings = Array.from(document.querySelectorAll(".prose h2[id]"));
    const tocLinks = Array.from(document.querySelectorAll(".toc-link"));

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const id = entry.target.getAttribute("id");
          if (!id) continue;
          const link = tocLinks.find((item) => item.getAttribute("data-target") === id);
          if (!link) continue;
          if (entry.isIntersecting) {
            tocLinks.forEach((item) => item.classList.remove("active"));
            link.classList.add("active");
          }
        }
      },
      { rootMargin: "-20% 0px -65% 0px", threshold: 0.1 },
    );
    headings.forEach((h) => io.observe(h));
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</BaseLayout>

<style>
  .post-layout {
    gap: 1.25rem;
  }

  .hero-image-wrap {
    position: relative;
    width: min(100%, 1120px);
    margin: 0;
    border-radius: 1.25rem;
    overflow: hidden;
    min-height: clamp(320px, 42vw, 500px);
    border: 1px solid var(--stroke-subtle);
  }

  .hero-image {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    filter: saturate(1.12) contrast(1.03);
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 10, 15, 0.2), rgba(8, 10, 15, 0.9) 72%);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    height: 100%;
    align-content: end;
    padding: clamp(1rem, 2.2vw, 1.8rem);
    max-width: 68ch;
  }

  .hero-copy h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.08;
  }

  .content-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) 300px;
    align-items: start;
  }

  .article {
    padding: 1rem;
    gap: 1rem;
  }

  .meta-top {
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(151, 171, 202, 0.23);
  }

  .pill-row {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .tags-row {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    padding-top: 0.7rem;
    border-top: 1px solid rgba(151, 171, 202, 0.23);
  }

  .tag {
    text-decoration: none;
    border: 1px solid rgba(243, 165, 58, 0.3);
    border-radius: 999px;
    padding: 0.24rem 0.62rem;
    color: #ffd8ab;
    font-size: 0.84rem;
    background: rgba(243, 165, 58, 0.1);
  }

  .tag:hover {
    background: rgba(243, 165, 58, 0.18);
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid rgba(151, 171, 202, 0.23);
    padding-top: 0.95rem;
  }

  .nav-link {
    text-decoration: none;
    padding: 0.75rem 0.85rem;
    color: var(--text-secondary);
  }

  .post-nav a:last-child {
    text-align: right;
  }

  .related {
    border-top: 1px solid rgba(151, 171, 202, 0.23);
    padding-top: 0.85rem;
  }

  .related ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.4rem;
  }

  .related a {
    text-decoration: none;
    color: #f2c88f;
  }

  .side {
    position: sticky;
    top: 110px;
    display: grid;
    gap: 0.9rem;
  }

  .side-card {
    gap: 0.7rem;
    padding: 0.9rem;
  }

  .side-card h3 {
    font-size: 1rem;
  }

  .side-card dl {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .side-card dt {
    color: var(--text-muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .side-card dd {
    margin: 0.15rem 0 0;
    color: var(--text-secondary);
  }

  .side-card ul {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.35rem;
  }

  .side-card a {
    color: #d3def2;
    text-decoration: none;
  }

  .side-card a:hover {
    color: #ffd7a7;
  }

  .toc-link.active {
    color: #ffcf8f;
    text-shadow: 0 0 14px rgba(243, 165, 58, 0.25);
  }

  @media (max-width: 980px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .side {
      position: static;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav a:last-child {
      text-align: left;
    }
  }
</style>
