---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { isVisible } from "../../lib/visibility";

const posts = (await getCollection("posts"))
  .filter((p) => isVisible(p.data.publishedAt))
  .sort((a, b) => (a.data.publishedAt || "") < (b.data.publishedAt || "") ? 1 : -1);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Tech Mage Blog",
  description: "All blog posts",
};
---

<BaseLayout title="Blog | Tech Mage" description="All blog posts">
  <section class="stack">
    <header class="page-hero stack">
      <h1>Blog</h1>
      <p class="muted">Long-form writing on engineering systems, leadership craft, and practical AI implementation.</p>
    </header>
    {posts.map((post) => <PostCard post={post} />)}
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</BaseLayout>
