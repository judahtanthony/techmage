---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";
---

<BaseLayout title="Search | Tech Mage" description="Search articles and thoughts">
  <section class="stack search-page">
    <header class="page-hero stack">
      <h1>Search</h1>
      <p class="muted">Find articles, tags, categories, and thought fragments across the archive.</p>
    </header>

    <form id="search-form" action="" method="get" class="search-shell ui-content-container" data-base={siteConfig.basePath}>
      <input id="search-input" name="q" type="search" placeholder="Search articles and thoughts" />
    </form>

    <div id="results" class="stack search-results"></div>
  </section>

  <script>
    const form = document.getElementById("search-form");
    const base = form?.dataset?.base || "/";
    const normalizedBase = base === "/" ? "" : base;
    const corpusPath = `${normalizedBase}/search-lunr.json`;

    const params = new URLSearchParams(window.location.search);
    const input = document.getElementById("search-input");
    const resultsEl = document.getElementById("results");
    let loaded = false;
    let lunrLib;
    let idx;
    let docs = [];

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    async function ensureLunrLoaded() {
      if (loaded) return;
      const [{ default: lunr }, corpus] = await Promise.all([
        import("lunr"),
        fetch(corpusPath).then((r) => r.json()),
      ]);

      lunrLib = lunr;
      docs = corpus;
      idx = lunr(function () {
        this.ref("id");
        this.field("title");
        this.field("category");
        this.field("tags");
        this.field("body");
        for (const doc of docs) this.add(doc);
      });
      loaded = true;
    }

    function render(rows) {
      if (!rows.length) {
        resultsEl.innerHTML = '<article class="card empty"><h3>No results yet</h3><p class="muted">Try broader terms, category names, or tag fragments.</p></article>';
        return;
      }
      resultsEl.innerHTML = rows
        .map((row) => {
          const href = `${normalizedBase}${row.url}`;
          const safeHref = escapeHtml(href);
          const safeTitle = escapeHtml(row.title);
          const meta = [row.category, row.tags].filter(Boolean).join(" • ");
          const safeMeta = escapeHtml(meta);
          return `<article class=\"card result fade-in\"><a class=\"title\" href=\"${safeHref}\">${safeTitle}</a><p class=\"muted\">${safeMeta}</p></article>`;
        })
        .join("");
    }

    function searchIndex(query) {
      const terms = query
        .trim()
        .toLowerCase()
        .split(/\s+/)
        .filter(Boolean);

      if (!terms.length) return [];

      return idx.query((builder) => {
        for (const term of terms) {
          builder.term(term, {
            boost: 10,
            usePipeline: true,
          });
          builder.term(term, {
            boost: 2,
            wildcard: lunrLib.Query.wildcard.TRAILING,
            usePipeline: true,
          });
        }
      });
    }

    async function runSearch(query) {
      const q = query.trim();
      if (!q) {
        render([]);
        return;
      }
      await ensureLunrLoaded();
      const hits = searchIndex(q);
      const byId = new Map(docs.map((d) => [d.id, d]));
      render(hits.map((h) => byId.get(h.ref)).filter(Boolean));
    }

    const initial = params.get("q") || "";
    input.value = initial;
    if (initial) runSearch(initial);
    else render([]);

    let timer;
    input.addEventListener("input", (e) => {
      clearTimeout(timer);
      timer = setTimeout(() => runSearch(e.target.value), 90);
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    gap: 0.95rem;
  }

  .search-shell {
    padding: 0.65rem;
  }

  .search-shell input {
    min-height: 3.1rem;
  }

  .search-results {
    gap: 0.78rem;
  }

  :global(.result) {
    display: grid;
    gap: 0.46rem;
    padding: 1rem;
  }

  :global(.result .title) {
    text-decoration: none;
    font-weight: 600;
    color: var(--text-primary);
  }

  :global(.result .title:hover) {
    color: #ffd6a2;
  }

  :global(.search-results .empty) {
    padding: 1rem;
  }

  :global(.search-results .empty h3) {
    margin-bottom: 0.32rem;
  }
</style>
