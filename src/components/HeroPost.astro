---
import type { CollectionEntry } from "astro:content";
import { resolvePermalink } from "../lib/content-path";
import { withBase } from "../lib/url";
import { formatContentDate } from "../lib/date";
import { buildResponsiveImage } from "../lib/media";
import { renderTeaserMarkdown, resolvePostTeaser } from "../lib/teaser";

type Props = {
  post?: CollectionEntry<"posts">;
};

const { post } = Astro.props as Props;
if (!post) {
  throw new Error("HeroPost requires a post");
}
const href = withBase(resolvePermalink({ ...post, collection: "posts" }));
const heroImage = buildResponsiveImage(post.data.image, post.slug, 1400, 700, "(min-width: 1120px) 1120px, 100vw");
const teaser = resolvePostTeaser(post, 220);
const teaserHtml = renderTeaserMarkdown(teaser);
---

<section class="hero ui-raised-panel-strong fade-in">
  <div class="ui-image-frame hero-media">
    <img
      class="hero-image"
      src={heroImage.src}
      srcset={heroImage.srcset}
      sizes={heroImage.sizes}
      width={heroImage.width}
      height={heroImage.height}
      alt={post.data.title}
      loading="eager"
      decoding="async"
    />
    <div class="overlay"></div>
  </div>
  <div class="hero-content stack">
    <span class="badge">Featured Story</span>
    <h1><a href={href}>{post.data.title}</a></h1>
    <p class="muted">{formatContentDate(post.data.publishedAt)}</p>
    <p class="desc" set:html={teaserHtml}></p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(320px, 46vw, 500px);
    padding: 0;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.03);
    filter: saturate(1.08);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 10, 15, 0.2), rgba(8, 10, 15, 0.9) 76%),
      linear-gradient(120deg, rgba(243, 165, 58, 0.17), transparent 45%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    height: 100%;
    align-content: end;
    padding: clamp(1.1rem, 3vw, 2rem);
    max-width: 760px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4.4vw, 3.1rem);
    line-height: 1.05;
  }

  .hero h1 a {
    text-decoration: none;
  }

  .hero h1 a:hover {
    color: #ffddad;
  }

  .desc {
    color: var(--text-secondary);
    max-width: 64ch;
  }
</style>
